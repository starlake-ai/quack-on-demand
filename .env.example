# Copy to `.env`, edit, then `./scripts/run-docker-compose.sh`.
#
# IMPORTANT: docker compose's .env parser does NOT support inline
# comments - anything after `KEY=` to end-of-line is taken as the value.
# Keep comments on their OWN lines (like this one), never on the same
# line as a KEY=VALUE pair.

# ----- Postgres metastore (the docker-compose Postgres service) -----
PG_USER=postgres
PG_PASSWORD=azizam
PG_DBNAME=tpch
PG_SCHEMA=main

# Host-exposed port for the in-compose Postgres. Bump if the host
# already runs Postgres on 5432 - the internal container port stays
# 5432, the manager talks to it via the service name `postgres` on the
# compose network, so only external psql/DBeaver access is affected.
# scripts/run-docker-compose.sh auto-bumps this to 15432 if it
# detects the host port is busy.
PG_PORT=15432

# ----- Quack-on-demand auth + TLS -----
#
# AUTH gates BOTH the FlightSQL edge AND the admin UI / REST API:
#   true  → DB-backed auth, admin user seeded from ADMIN_USERNAME /
#           ADMIN_PASSWORD, UI login works with those credentials.
#   false → no auth backend; the UI cannot log in and `/api/*` returns
#           401 unless API_KEY is set (and clients send X-API-Key).
# Default ON because that's what the demo UI flow expects.
AUTH=true

# Seeded into slkstate_user when AUTH=true. ROTATE the password before
# exposing the edge beyond localhost.
ADMIN_USERNAME=admin@localhost.local,admin
ADMIN_PASSWORD=admin

# Optional static REST key. Blank = no static key; clients authenticate
# via the UI login flow and a session token. Set to bypass login with
# an X-API-Key header.
API_KEY=

# `true` enables FlightSQL edge TLS (cert auto-generated under ./certs).
# When `true`, the loadtest's --url must be grpc+tls://… ; when `false`,
# use grpc://… instead.
TLS=true

# ----- Host ports -----
MANAGER_PORT=20900
EDGE_PORT=31338
QUACK_MIN_PORT=21900
QUACK_MAX_PORT=22500

# ----- Optional one-shot TPCH loader -----
#
# Generates TPCH data into PG_DBNAME via DuckDB's dbgen() table function.
# Driven by run-docker-compose.sh:
#   LOAD_TPCH=true ./scripts/run-docker-compose.sh
# Or against a running stack:
#   docker compose exec quack /app/scripts/load-tpch-dbgen.sh
#
# TPCH_SF=1 generates ~6M lineitem rows; SF=10 is ~60M.
# TPCH_SCHEMA is the DuckLake schema; MUST differ from PG_DBNAME.
TPCH_SF=1
TPCH_SCHEMA=tpch1

# ----- Optional: DuckLake on S3-compatible object storage -----
#
# Out of the box DuckLake writes parquet under ./ducklake (host bind-mount).
# To switch to an S3-compatible bucket - SeaweedFS, MinIO, AWS S3, R2, GCS
# via the HMAC/S3-interop endpoint - set SL_QUACK_DUCKLAKE_DATA_PATH to an
# s3:// URL and fill in the SL_QUACK_S3_* credentials below. spawn-quack-node.sh
# and load-tpch-dbgen.sh detect the scheme, install httpfs, and CREATE SECRET
# so every Quack node reads/writes parquet against the bucket.
#
# ---- Option A: SeaweedFS in compose (zero external dependencies) ----
# Bring up the bundled SeaweedFS with:
#   docker compose --profile seaweedfs up -d
# then uncomment the four lines below. seaweedfs:8333 resolves on the
# compose network; the matching service is in docker-compose.yml.
#
#SL_QUACK_DUCKLAKE_DATA_PATH=s3://ducklake/tpch
#SL_QUACK_S3_ENDPOINT=seaweedfs:8333
#SL_QUACK_S3_ACCESS_KEY_ID=quack
#SL_QUACK_S3_SECRET_ACCESS_KEY=quackquack
#SL_QUACK_S3_USE_SSL=false
#SL_QUACK_S3_URL_STYLE=path
#S3_BUCKET=ducklake
#
# ---- Option B: External AWS S3 (or any S3-compatible endpoint) ----
# Leave the seaweedfs profile off; just set the bucket + credentials.
# Omit SL_QUACK_S3_ENDPOINT to use the AWS default (s3.amazonaws.com).
#
#SL_QUACK_DUCKLAKE_DATA_PATH=s3://my-bucket/quack/tpch
#SL_QUACK_S3_ACCESS_KEY_ID=AKIA...
#SL_QUACK_S3_SECRET_ACCESS_KEY=...
#SL_QUACK_S3_REGION=us-east-1
#SL_QUACK_S3_USE_SSL=true
#SL_QUACK_S3_URL_STYLE=vhost

# ----- Optional corporate proxy -----
#
# Set these when the host needs an HTTP proxy to reach the public
# internet (extensions.duckdb.org for DuckDB's `INSTALL quack` /
# `INSTALL tpch` / etc.). compose forwards them into the container,
# the manager translates HTTP_PROXY into DuckDB's `SET http_proxy`
# before INSTALL, and spawn-quack-node.sh does the same for child
# Quack nodes. Leave blank on non-proxied networks.
#
# Note: `docker pull` itself reads the daemon's proxy config, NOT
# these vars - configure ~/.docker/config.json or systemd unit
# overrides if `docker compose pull` also needs to traverse the proxy.
#HTTP_PROXY=http://proxy.corp.example:3128
#HTTPS_PROXY=http://proxy.corp.example:3128
#NO_PROXY=localhost,127.0.0.1,postgres,.corp.example