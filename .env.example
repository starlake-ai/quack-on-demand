# Copy to `.env`, edit, then `docker compose up`.

# ----- Postgres metastore (the docker-compose Postgres service) -----
PG_USER=postgres
PG_PASSWORD=azizam
PG_DBNAME=tpch
PG_SCHEMA=main
PG_PORT=5432            # host-exposed port for the in-compose Postgres.
                        # Bump to e.g. 15432 if you already run Postgres
                        # on host:5432 — internal container port stays
                        # 5432, the manager talks to it via the service
                        # name "postgres" on the compose network, so only
                        # external psql/DBeaver access is affected.

# ----- Quack-on-demand auth + TLS -----
AUTH=false              # `true` enables DB auth on the FlightSQL edge
ADMIN_USERNAME=admin    # seeded when AUTH=true
ADMIN_PASSWORD=admin    # ROTATE before exposing the edge beyond localhost
API_KEY=                # leave blank for an open REST API; set to lock it down
TLS=false               # `true` enables FlightSQL edge TLS (cert auto-generated)

# ----- Host ports -----
MANAGER_PORT=20900      # REST + UI
EDGE_PORT=31338         # FlightSQL edge
QUACK_MIN_PORT=21900    # first lease port for local-mode Quack nodes
QUACK_MAX_PORT=22500    # last  lease port (default: 600 nodes)

# ----- Optional one-shot TPCH loader (the `init` compose profile) -----
# Generates TPCH data into PG_DBNAME via DuckDB's dbgen() table function.
# Triggered explicitly:  docker compose --profile init run --rm init-tpch
TPCH_SF=1               # scale factor (1 = ~6M lineitem rows)
TPCH_SCHEMA=tpch1       # schema inside PG_DBNAME — MUST differ from PG_DBNAME